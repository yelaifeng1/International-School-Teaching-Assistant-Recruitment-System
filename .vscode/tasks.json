{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: Clean Compile",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "compile"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "focus": false,
        "showReuseMessage": true
      },
      "problemMatcher": ["$java"]
    },
    {
      "label": "Maven: Build WAR",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "package"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "VS Code: Reload Java",
      "type": "shell",
      "command": "echo",
      "args": ["请手动: Ctrl+Shift+P > 'Java: Clear Java Language Server Workspace'"],
      "presentation": {
        "reveal": "always",
        "echo": true
      }
    }
  ]
}
